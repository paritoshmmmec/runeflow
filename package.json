{
  "name": "runeflow",
  "version": "0.3.0",
  "description": "Hybrid markdown + DSL runtime for executable AI skills, typed steps, and JSON run artifacts",
  "type": "module",
  "types": "index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/paritoshmmmec/runeflow"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin/",
    "src/",
    "registry/",
    "examples/",
    "index.d.ts",
    "README.md"
  ],
  "bin": {
    "runeflow": "./bin/runeflow.js"
  },
  "scripts": {
    "test": "node --test",
    "validate:example": "node ./bin/runeflow.js validate ./examples/open-pr.runeflow.md",
    "validate:block-demo": "node ./bin/runeflow.js validate ./examples/block-demo.runeflow.md",
    "validate:release-notes": "node ./bin/runeflow.js validate ./examples/release-notes.runeflow.md",
    "eval:open-pr": "node --env-file=.env ./eval/open-pr.js --base-branch main",
    "eval:3p": "node --env-file=.env ./eval/3p-updates.js",
    "eval:addresszen": "node --env-file=.env ./eval/addresszen-automation.js --delay-ms 5000",
    "eval:adyntel": "node --env-file=.env ./eval/adyntel-automation.js --mode both --delay-ms 8000",
    "eval:release-notes": "node --env-file=.env ./eval/release-notes.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.149",
    "chokidar": "^5.0.0",
    "node-cron": "^4.2.1",
    "tiktoken": "^1.0.22",
    "yaml": "^2.8.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": ">=1.0.0",
    "@ai-sdk/cerebras": ">=1.0.0",
    "@ai-sdk/google": ">=1.0.0",
    "@ai-sdk/groq": ">=1.0.0",
    "@ai-sdk/mistral": ">=1.0.0",
    "@ai-sdk/openai": ">=1.0.0",
    "@composio/core": ">=0.6.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/cerebras": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@ai-sdk/groq": {
      "optional": true
    },
    "@ai-sdk/mistral": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    },
    "@composio/core": {
      "optional": true
    }
  }
}
